# LocalStack Configuration
# This file contains environment variables for LocalStack local development

# AWS Credentials (LocalStack uses these for local emulation)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_SESSION_TOKEN=test
AWS_DEFAULT_REGION=us-east-1

# LocalStack Endpoint
LOCALSTACK_ENDPOINT=http://localhost:4566

# Enable persistence (data survives container restarts)
PERSISTENCE=1

# LocalStack data directory
LOCALSTACK_VOLUME_DIR=./.localstack

# Debug mode (set to 1 for verbose logging)
DEBUG=0

